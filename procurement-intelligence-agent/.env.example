# ─────────────────────────────────────────────
# AWS Configuration
# ─────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# IAM Role ARN for Bedrock access (used in production; local uses profile)
BEDROCK_ROLE_ARN=arn:aws:iam::123456789012:role/procurement-bedrock-role

# ─────────────────────────────────────────────
# AWS Bedrock
# ─────────────────────────────────────────────
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_GUARDRAIL_ID=your-guardrail-id
BEDROCK_GUARDRAIL_VERSION=DRAFT

# ─────────────────────────────────────────────
# Pinecone
# ─────────────────────────────────────────────
PINECONE_API_KEY=pcsk_xxxxxxxxxxxx
PINECONE_INDEX_NAME=procurement-docs
PINECONE_ENVIRONMENT=us-east-1-aws

# ─────────────────────────────────────────────
# Cohere (Reranker)
# ─────────────────────────────────────────────
COHERE_API_KEY=xxxxxxxxxxxx

# ─────────────────────────────────────────────
# Perplexity (Web Search)
# ─────────────────────────────────────────────
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxx
PERPLEXITY_BASE_URL=https://api.perplexity.ai

# ─────────────────────────────────────────────
# AWS RDS MySQL
# ─────────────────────────────────────────────
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=3306
DB_NAME=procurement
DB_USER=admin
DB_PASSWORD=changeme_use_secrets_manager_in_prod

# ─────────────────────────────────────────────
# LangSmith
# ─────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_xxxxxxxxxxxx
LANGCHAIN_PROJECT=procurement-intelligence-agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ─────────────────────────────────────────────
# JWT Authentication
# ─────────────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-prod
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─────────────────────────────────────────────
# API Service
# ─────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
CORS_ORIGINS=["http://localhost:3000","http://localhost:8501"]

# ─────────────────────────────────────────────
# MCP Server
# ─────────────────────────────────────────────
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8080

# ─────────────────────────────────────────────
# S3 Document Storage
# ─────────────────────────────────────────────
S3_BUCKET_NAME=procurement-intelligence-docs
S3_PREFIX=documents/

# ─────────────────────────────────────────────
# Guardrail Tier Config
# ─────────────────────────────────────────────
INTERNAL_MAX_TOKENS=50000
PARTNER_MAX_TOKENS=20000
PUBLIC_MAX_TOKENS=8000
